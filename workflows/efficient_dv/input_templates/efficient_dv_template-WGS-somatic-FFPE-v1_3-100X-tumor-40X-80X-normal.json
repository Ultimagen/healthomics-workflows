{
    "EfficientDV.base_file_name": "<base_file_name>",
    "EfficientDV.cram_files": [
        "<cram_file>.cram"
    ],
    "EfficientDV.cram_index_files": [
        "<cram_file>.cram.crai"
    ],
    "EfficientDV.num_shards": 50,
    "EfficientDV.make_gvcf": false,
    "EfficientDV.recalibrate_vaf": true,
    "EfficientDV.is_somatic": true,
    "EfficientDV.single_strand_filter": true,
    "EfficientDV.min_fraction_single_strand_non_snps": 0.15,
    "EfficientDV.reference_genome": "hg38",
    "EfficientDV.preemptible_tries": 2,
    "EfficientDV.cap_at_optimal_coverage": false,
    "EfficientDV.normalize_strand_bias": false,
    "EfficientDV.strong_call_threshold": 1.1,
    "EfficientDV.background_cram_files": [
        "<normal_cram_file>.cram"
    ],
    "EfficientDV.background_cram_index_files": [
        "<normal_cram_file>.cram.crai"
    ],
    "EfficientDV.model_onnx": "s3://ultimagen-workflow-resources-us-east-1/deepvariant/model/somatic/wgs/ffpe/deepvariant-ultima-somatic-wgs-ffpe-model-v1.3.ckpt-890000.onnx",
    "EfficientDV.keep_duplicates": false,
    "EfficientDV.add_ins_size_channel": true,
    "EfficientDV.ug_make_examples_extra_args": "--channels hmer_deletion_quality,hmer_insertion_quality,non_hmer_insertion_quality,soft_clips",
    "EfficientDV.min_fraction_hmer_indels": 0.03,
    "EfficientDV.min_fraction_non_hmer_indels": 0.03,
    "EfficientDV.min_fraction_snps": 0.03,
    "EfficientDV.min_variant_quality_hmer_indels": 10,
    "EfficientDV.min_variant_quality_exome_hmer_indels": 10,
    "EfficientDV.min_variant_quality_non_hmer_indels": 10,
    "EfficientDV.min_variant_quality_snps": 10,
    "EfficientDV.allele_frequency_ratio": 10,
    "EfficientDV.optimal_coverages": [
        100,
        80
    ],
    "EfficientDV.ug_make_examples_memory_override": 4,
    "EfficientDV.cloud_provider_override": "aws",
    "EfficientDV.monitoring_script_input": "s3://ultimagen-workflow-resources-us-east-1/monitor_1.0.sh"
}